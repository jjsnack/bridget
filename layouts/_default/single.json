{{- $context := . -}}
{{- $params := .Page.Params | merge .Site.Params.Page -}}

{{- with partial "function/getImageSlice.html" .  -}}
  {{- $index := len . -}}
  {{- $context.Scratch.Add "img" slice -}}
  {{- range sort . "Name" "desc" -}}
    {{- $image := . -}}
    {{- $index = sub $index 1 -}}
    {{- $alt := .Name -}}
    {{- with $params.unifiedAlt -}}
      {{- $alt = . -}}
    {{- end -}}
    {{- /* explicit spec keeps the scatter's distinct dev sizes (640/700/2000); in prod imgSrc emits CDN URLs by size class (mo+lo -> cdnLoQuery, hi -> cdnHiQuery) */ -}}
    {{- $mores := partial "function/imgSrc.html" (dict "img" $image "page" $context "size" "lo" "spec" (site.Params.moResOpt | default "640x webp Lanczos q60")) -}}
    {{- $lores := partial "function/imgSrc.html" (dict "img" $image "page" $context "size" "lo" "spec" (site.Params.loResOpt | default "700x webp Lanczos q60")) -}}
    {{- $hires := partial "function/imgSrc.html" (dict "img" $image "page" $context "size" "hi" "spec" (site.Params.hiResOpt | default "2000x webp Lanczos q75")) -}}
    {{- $context.Scratch.Add "img" (dict
      "index" (int $index)
      "alt" (string $alt)
      "moUrl" (string $mores.url)
      "moImgH" (int $mores.h)
      "moImgW" (int $mores.w)
      "loUrl" (string $lores.url)
      "loImgH" (int $lores.h)
      "loImgW" (int $lores.w)
      "hiUrl" (string $hires.url)
      "hiImgH" (int $hires.h)
      "hiImgW" (int $hires.w)
      )
    -}}
  {{- end -}}
    {{ $context.Scratch.Get "img" | jsonify }}
{{- else -}}
[]
{{- end -}}
